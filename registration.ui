  <property name="styleSheet">
   <string notr="true">QWidget#Registration {
    background-color: #ffffff;
    border-radius: 48px;
}

/* Статус бар */
QLabel#status_bar {
    color: #000000;
    font-family: 'Cairo';
    font-size: 17px;
    font-weight: 500;
}

/* Заголовок Регистрация */
QLabel#registration_title {
    color: #000000;
    font-family: 'Montserrat';
    font-size: 48px;
    font-weight: 300;
}

/* Поля ввода */
QLineEdit {
    border: 1.25px solid rgba(255, 255, 255, 0.7);
    border-radius: 10px;
    padding: 15px;
    padding-left: 60px;
    font-family: 'Montserrat';
    font-size: 25px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    background-color: transparent;
}

QLineEdit:focus {
    border-color: rgba(255, 255, 255, 0.9);
}

QLineEdit#name_field {
    background-image: url(:/assets/rectangle_2_1.png);
    background-repeat: no-repeat;
}

QLineEdit#email_field {
    background-image: url(:/assets/rectangle_1_1.png);
    background-repeat: no-repeat;
}

QLineEdit#password_field {
    background-image: url(:/assets/rectangle_3_1.png);
    background-repeat: no-repeat;
    padding-right: 60px;
}

/* Кнопка Зарегистрироваться */
QPushButton#register_button {
    background-image: url(:/assets/rectangle_4.png);
    background-repeat: no-repeat;
    border: none;
    border-radius: 10px;
    color: rgba(255, 255, 255, 0.7);
    font-family: 'Montserrat';
    font-size: 25px;
    font-weight: 400;
    padding: 20px 0;
}

QPushButton#register_button:hover {
    background-color: rgba(0, 0, 0, 0.1);
}

QPushButton#register_button:pressed {
    background-color: rgba(0, 0, 0, 0.2);
}

/* Текст &quot;Войти с помощью&quot; */
QLabel#login_with_label {
    color: rgba(0, 0, 0, 0.8);
    font-family: 'Montserrat';
    font-size: 25px;
    font-weight: 300;
}

/* Круглые кнопки соцсетей */
QPushButton.social_button {
    border-radius: 24px;
    border: none;
    background-color: transparent;
    min-width: 54px;
    min-height: 54px;
    max-width: 54px;
    max-height: 54px;
}

QPushButton#google_button {
    background-image: url(:/assets/ellipse_2_1.png);
    background-repeat: no-repeat;
}

QPushButton#apple_button {
    background-image: url(:/assets/ellipse_1_1.png);
    background-repeat: no-repeat;
}

QPushButton#phone_button {
    background-image: url(:/assets/ellipse_3_1.png);
    background-repeat: no-repeat;
}

/* Индикатор дома */
QFrame#home_indicator {
    background-color: #000000;
    border-radius: 100px;
}

/* Иконки в полях ввода */
QLabel.field_icon {
    background-color: transparent;
    border: none;
}

/* Батарея */
QWidget#battery_widget {
    background-color: transparent;
}

/* Кнопка глаза для пароля */
QPushButton#eye_button {
    background-color: transparent;
    border: none;
    padding: 0;
    margin: 0;
}

/* Иконка пользователя для поля имени */
QLabel#user_icon {
    background-image: url(:/assets/user_icon.png);
    background-repeat: no-repeat;
    background-position: center;
    min-width: 24px;
    min-height: 24px;
}

/* Иконка почты для поля email */
QLabel#email_icon {
    background-image: url(:/assets/email_icon.png);
    background-repeat: no-repeat;
    background-position: center;
    min-width: 24px;
    min-height: 24px;
}

/* Иконка замка для поля пароля */
QLabel#lock_icon {
    background-image: url(:/assets/lock_icon.png);
    background-repeat: no-repeat;
    background-position: center;
    min-width: 24px;
    min-height: 24px;
}</string>
